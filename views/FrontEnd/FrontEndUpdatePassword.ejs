<%- include('FrontEndHeader') %>

<div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card shadow-lg">
          <div class="card-body">
            <h4 class="card-title mb-4">Update Password</h4>
            <form action="/updatepass" method="post">
              <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" name="newPassword" class="form-control" id="newPassword" placeholder="Enter new password" required>
              </div>
              <div class="mb-3">
                <label for="reNewPassword" class="form-label">Re-enter New Password</label>
                <input type="password" name="confirmPassword" class="form-control" id="reNewPassword" placeholder="Re-enter new password" required>
              </div>
              <button type="submit" class="btn btn-primary w-100">Update Password</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>





<%- include('FrontEndFooter')%>